# Real Outlook and Gmail acceptance credentials. Never commit the populated file.
# Use disposable sender accounts and controlled recipient mailboxes only.
OUTLOOK_LIVE_REFRESH_TOKEN=
OUTLOOK_LIVE_SINK_ADDRESS=
GMAIL_LIVE_REFRESH_TOKEN=
GMAIL_LIVE_SINK_ADDRESS=

# A live run sends one benign, uniquely marked message per configured provider.
CONNECTOR_EMAIL_LIVE_SEND=false
