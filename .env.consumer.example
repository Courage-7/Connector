# Create this key once with POST /v1/admin/projects. It cannot be retrieved later.
CONNECTOR_CONSUMER_API_KEY=

# HTTP is accepted only for localhost. Use HTTPS for a remote deployment.
CONNECTOR_MCP_BASE_URL=http://127.0.0.1:8010
CONNECTOR_MCP_TIMEOUT_SECONDS=30
CONNECTOR_MCP_ENABLED_PROVIDERS=supabase,outlook,gmail
