CONNECTOR_ENVIRONMENT=development
CONNECTOR_DATABASE_URL=sqlite:///./connector_service.db
CONNECTOR_ADMIN_TOKEN=replace-with-at-least-32-random-characters
CONNECTOR_CREDENTIAL_ENCRYPTION_KEY=replace-with-a-fernet-key
CONNECTOR_CURSOR_SIGNING_KEY=replace-with-at-least-32-random-characters
CONNECTOR_AUTO_CREATE_SCHEMA=false
CONNECTOR_LOG_LEVEL=INFO
CONNECTOR_PROVIDER_TIMEOUT_SECONDS=15
CONNECTOR_PROVIDER_MAX_RETRIES=2
CONNECTOR_PROVIDER_RETRY_BASE_SECONDS=0.25
CONNECTOR_MAX_PROVIDER_RESPONSE_BYTES=5242880
CONNECTOR_MAX_PAGE_SIZE=100
CONNECTOR_DASHBOARD_LOGIN_TICKET_TTL_SECONDS=120
CONNECTOR_DASHBOARD_SESSION_TTL_SECONDS=28800

# Register an OAuth app in Supabase Organization Settings > OAuth Apps.
# Configure only the projects:read and database:read scopes.
CONNECTOR_SUPABASE_OAUTH_CLIENT_ID=
CONNECTOR_SUPABASE_OAUTH_CLIENT_SECRET=
CONNECTOR_SUPABASE_OAUTH_REDIRECT_URI=http://localhost:8000/v1/connections/supabase/callback
CONNECTOR_SUPABASE_MANAGEMENT_API_URL=https://api.supabase.com
CONNECTOR_SUPABASE_OAUTH_ATTEMPT_TTL_SECONDS=600
CONNECTOR_SUPABASE_OAUTH_TOKEN_SKEW_SECONDS=60

# Register a confidential web app in Microsoft Entra ID.
# Delegated scopes: openid profile email offline_access User.Read Mail.ReadWrite Mail.Send.
CONNECTOR_OUTLOOK_OAUTH_CLIENT_ID=
CONNECTOR_OUTLOOK_OAUTH_CLIENT_SECRET=
CONNECTOR_OUTLOOK_OAUTH_REDIRECT_URI=http://localhost:8000/v1/connections/outlook/callback
CONNECTOR_OUTLOOK_OAUTH_AUTHORITY=https://login.microsoftonline.com/common/oauth2/v2.0
CONNECTOR_OUTLOOK_GRAPH_API_URL=https://graph.microsoft.com/v1.0

# Enable Gmail API and create a Google OAuth web client.
# Scopes: openid email, gmail.readonly, and gmail.compose.
CONNECTOR_GMAIL_OAUTH_CLIENT_ID=
CONNECTOR_GMAIL_OAUTH_CLIENT_SECRET=
CONNECTOR_GMAIL_OAUTH_REDIRECT_URI=http://localhost:8000/v1/connections/gmail/callback
CONNECTOR_GMAIL_OAUTH_AUTHORITY=https://accounts.google.com/o/oauth2/v2
CONNECTOR_GMAIL_TOKEN_URL=https://oauth2.googleapis.com
CONNECTOR_GMAIL_USERINFO_URL=https://openidconnect.googleapis.com/v1
CONNECTOR_GMAIL_API_URL=https://gmail.googleapis.com/gmail/v1

CONNECTOR_EMAIL_OAUTH_ATTEMPT_TTL_SECONDS=600
CONNECTOR_EMAIL_OAUTH_TOKEN_SKEW_SECONDS=60
CONNECTOR_EMAIL_SEND_APPROVAL_TTL_SECONDS=1800
