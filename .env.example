# Connector Service has one local environment file: copy this file to `.env`.
# Never commit `.env`. Production should inject the same names from a secret manager.

APP_NAME=Connector Service
ENVIRONMENT=development
LOG_LEVEL=INFO

# Dedicated Supabase Postgres database used only for connector metadata and encrypted tokens.
# Copy a PostgreSQL URI from the Supabase project's Connect dialog and URL-encode its password.
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/postgres?sslmode=require
# Convenient locally. Set false in production and run `alembic upgrade head` during deploy.
AUTO_CREATE_SCHEMA=true

# Development: one static Bearer token. Production: use `supabase_jwt` instead.
AUTH_MODE=static
SERVICE_BEARER_TOKEN=GENERATE_A_RANDOM_TOKEN
DEVELOPMENT_SUBJECT=local-development-user

# Fernet key used to encrypt provider access and refresh tokens before database storage.
TOKEN_ENCRYPTION_KEY=GENERATE_A_FERNET_KEY
OAUTH_TRANSACTION_TTL_SECONDS=600
PROVIDER_TIMEOUT_SECONDS=15
MAX_PROVIDER_RESPONSE_BYTES=5242880

# Production identity (required only when AUTH_MODE=supabase_jwt).
# This may be the same Supabase project used by your B2C application.
SUPABASE_AUTH_URL=https://YOUR_AUTH_PROJECT_REF.supabase.co
SUPABASE_AUTH_AUDIENCE=authenticated
JWKS_CACHE_SECONDS=300

# Supabase provider integration (implemented in this phase).
# Register exactly: http://localhost:1080/v1/oauth/supabase/callback
# OAuth app scopes: projects:read and database:read.
SUPABASE_OAUTH_CLIENT_ID=
SUPABASE_OAUTH_CLIENT_SECRET=
SUPABASE_OAUTH_REDIRECT_URI=http://localhost:1080/v1/oauth/supabase/callback
SUPABASE_MANAGEMENT_API_URL=https://api.supabase.com
SUPABASE_OAUTH_TOKEN_SKEW_SECONDS=60

# Google Workspace provider (planned next; visible but not executable yet).
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REDIRECT_URI=http://localhost:1080/v1/oauth/google_workspace/callback
GMAIL_OAUTH_AUTHORITY=https://accounts.google.com/o/oauth2/v2
GMAIL_TOKEN_URL=https://oauth2.googleapis.com
GMAIL_USERINFO_URL=https://openidconnect.googleapis.com/v1
GMAIL_API_URL=https://gmail.googleapis.com/gmail/v1
GOOGLE_CALENDAR_API_URL=https://www.googleapis.com/calendar/v3

# Microsoft 365 provider (planned next; visible but not executable yet).
OUTLOOK_OAUTH_CLIENT_ID=
OUTLOOK_OAUTH_CLIENT_SECRET=
OUTLOOK_OAUTH_REDIRECT_URI=http://localhost:1080/v1/oauth/microsoft_365/callback
OUTLOOK_OAUTH_AUTHORITY=https://login.microsoftonline.com/common/oauth2/v2.0
OUTLOOK_GRAPH_API_URL=https://graph.microsoft.com/v1.0
