# Optional real-provider acceptance tests. Never commit the populated file.
# Setup guide: docs/configuration/environment-setup.md#10-optional-live-test-credentials

# Supabase Management API discovery and bounded query test.
# Generate a temporary account access token only for local acceptance testing.
SUPABASE_MANAGEMENT_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=
SUPABASE_LIVE_SCHEMA=public
SUPABASE_LIVE_TABLE=
SUPABASE_LIVE_COLUMNS=id,status,created_at

# Supabase full service-path test against a disposable Data API table.
# Use a backend-only secret/service-role key; never expose it to a browser.
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_LIVE_RESOURCE=
SUPABASE_LIVE_ID_COLUMN=id
SUPABASE_LIVE_AUTHORIZATION_TOKEN=
SUPABASE_LIVE_LIMIT=5

# Outlook and Gmail acceptance tests.
# Use disposable sender accounts and controlled recipient mailboxes only.
OUTLOOK_LIVE_REFRESH_TOKEN=
OUTLOOK_LIVE_SINK_ADDRESS=
GMAIL_LIVE_REFRESH_TOKEN=
GMAIL_LIVE_SINK_ADDRESS=

# A live run sends one benign, uniquely marked message per configured provider.
CONNECTOR_EMAIL_LIVE_SEND=false
